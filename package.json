{
  "name": "@uraniumtech/ui",
  "version": "0.5.0",
  "description": "Uranium Technologies design system: brand tokens, React components, and D3 chart wrappers. Agent catalog in llms.txt.",
  "type": "module",
  "license": "MIT",
  "repository": "github:cincybc/ut-ui",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens.css": "./src/styles/tokens.css",
    "./llms.txt": "./llms.txt",
    "./manifest.json": "./manifest.json",
    "./eslint": "./eslint.config.shared.mjs"
  },
  "files": [
    "dist",
    "src",
    "llms.txt",
    "manifest.json",
    "eslint.config.shared.mjs"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit && vitest run && node scripts/check-manifest.mjs",
    "check:manifest": "node scripts/check-manifest.mjs",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "test:visual": "playwright test tests/visual.spec.ts"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "lucide-react": ">=0.400.0"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "typescript-eslint": "^8.63.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^25.0.1",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

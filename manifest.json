{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "@uraniumtech/ui",
  "description": "Machine-readable component catalog. Human/agent version: llms.txt",
  "components": [
    {
      "name": "Button",
      "import": "import { Button } from '@uraniumtech/ui'",
      "source": "src/components/Button.tsx",
      "replaces": ["hand-styled <button>", ".btn-* classes"],
      "props": "variant?='primary'|'accent'|'ghost'; size?='sm'|'md'; native button props",
      "example": "<Button variant=\"ghost\" size=\"sm\">Reset</Button>"
    },
    {
      "name": "Kicker",
      "import": "import { Kicker } from '@uraniumtech/ui'",
      "source": "src/components/Kicker.tsx",
      "replaces": ["hand-styled uppercase section labels"],
      "props": "children; className?",
      "example": "<Kicker>Supply & Demand</Kicker>"
    },
    {
      "name": "Badge",
      "import": "import { Badge } from '@uraniumtech/ui'",
      "source": "src/components/Badge.tsx",
      "replaces": ["inline status pills like bg-green-500/20"],
      "props": "tone?='neutral'|'green'|'teal'|'petrol'|'amber'|'rust'; children",
      "example": "<Badge tone=\"amber\">Stale</Badge>"
    },
    {
      "name": "StatusBadge",
      "import": "import { StatusBadge } from '@uraniumtech/ui'",
      "source": "src/components/Badge.tsx",
      "replaces": ["status pills with dots"],
      "props": "tone?; children",
      "example": "<StatusBadge tone=\"green\">Operational</StatusBadge>"
    },
    {
      "name": "Card",
      "import": "import { Card } from '@uraniumtech/ui'",
      "source": "src/components/Card.tsx",
      "replaces": ["bg-[#27293d] card divs", "hand-rolled cards"],
      "props": "title?; label?; headerContent?; live?; className?; children",
      "example": "<Card title=\"Forward Curve\" label=\"Numerco\">…</Card>"
    },
    {
      "name": "PageHeader",
      "import": "import { PageHeader } from '@uraniumtech/ui'",
      "source": "src/components/PageHeader.tsx",
      "replaces": ["hand-rolled page title blocks"],
      "props": "title; kicker?; description?; actions?",
      "example": "<PageHeader title=\"Reactor Data\" kicker=\"IAEA PRIS\" />"
    },
    {
      "name": "StatCard",
      "import": "import { StatCard } from '@uraniumtech/ui'",
      "source": "src/components/StatCard.tsx",
      "replaces": ["KPI/stat tiles", "legacy StatsCard"],
      "props": "value; label?; icon?; accent?='green'|'teal'|'petrol'|'amber'|'rust'; delta?={value,format?}; footer?; live?",
      "example": "<StatCard value=\"$82.50\" label=\"Spot U3O8\" accent=\"green\" delta={{ value: 1.25 }} />"
    },
    {
      "name": "SegmentedControl",
      "import": "import { SegmentedControl } from '@uraniumtech/ui'",
      "source": "src/components/SegmentedControl.tsx",
      "replaces": ["filter button rows (MAX/5Y/1Y/1M/1W pattern)"],
      "props": "options; value; onChange; size?; ariaLabel (required)",
      "example": "<SegmentedControl options={['MAX','5Y','1Y']} value={r} onChange={setR} ariaLabel=\"Time range\" />"
    },
    {
      "name": "Tabs",
      "import": "import { Tabs } from '@uraniumtech/ui'",
      "source": "src/components/Tabs.tsx",
      "replaces": ["hand-rolled tab bars"],
      "props": "tabs; value; onChange; ariaLabel; children?",
      "example": "<Tabs tabs={[{value:'us',label:'US'}]} value=\"us\" onChange={setR} ariaLabel=\"Region\" />"
    },
    {
      "name": "Tooltip",
      "import": "import { Tooltip } from '@uraniumtech/ui'",
      "source": "src/components/Tooltip.tsx",
      "replaces": ["title attributes", "hand-rolled hover popups"],
      "props": "content; side?; children",
      "example": "<Tooltip content=\"lbs U3O8\"><button>?</button></Tooltip>"
    },
    {
      "name": "ThemeToggle",
      "import": "import { ThemeToggle, themeInitScript } from '@uraniumtech/ui'",
      "source": "src/components/ThemeToggle.tsx",
      "replaces": ["hand-rolled light/dark switches", "manual data-theme toggling"],
      "props": "className?",
      "example": "<ThemeToggle />"
    },
    {
      "name": "DataTable",
      "import": "import { DataTable } from '@uraniumtech/ui'",
      "source": "src/components/DataTable.tsx",
      "replaces": ["any raw <table> markup"],
      "props": "columns {key,header,cell?,numeric?,sortable?,sortValue?,align?,width?}[]; rows; getRowKey; defaultSort?; stickyHeader?=true; density?; onRowClick?; emptyState?; caption?",
      "example": "<DataTable rows={rows} getRowKey={r=>r.id} columns={[{key:'name',header:'Reactor',sortable:true}]} />"
    },
    {
      "name": "LineChart",
      "import": "import { LineChart } from '@uraniumtech/ui'",
      "source": "src/charts/LineChart.tsx",
      "replaces": ["d3.select code", "hand-rolled svg line charts"],
      "props": "series {id,label?,data:{x,y}[],color?,dashed?,area?}[]; height?; yFormat?; grid?; tooltip?; legend?; zeroBaseline?=false; ariaLabel (required)",
      "example": "<LineChart ariaLabel=\"Spot\" series={[{id:'spot',data:pts}]} />"
    },
    {
      "name": "BarChart",
      "import": "import { BarChart } from '@uraniumtech/ui'",
      "source": "src/charts/BarChart.tsx",
      "replaces": ["d3 bar code", "hand-rolled svg bars"],
      "props": "series {id,label?,color?,data:{category,value}[]}[]; stacked?=true; height?; yFormat?; legend?; tooltip?; ariaLabel (required)",
      "example": "<BarChart ariaLabel=\"Imports\" series={[{id:'ca',data:rows}]} />"
    },
    {
      "name": "FormField",
      "import": "import { FormField } from '@uraniumtech/ui'",
      "source": "src/components/FormField.tsx",
      "replaces": ["hand-rolled label/error/hint markup around form controls"],
      "props": "label; htmlFor; hint?; error?; children (single control); className?",
      "example": "<FormField label=\"Quantity\" htmlFor=\"qty\" hint=\"In pounds U3O8\"><Input id=\"qty\" /></FormField>"
    },
    {
      "name": "Input",
      "import": "import { Input } from '@uraniumtech/ui'",
      "source": "src/components/Input.tsx",
      "replaces": ["hand-styled <input>", "ad-hoc numeric formatting"],
      "props": "icon?; ...native input props",
      "example": "<Input type=\"number\" aria-label=\"Price\" />"
    },
    {
      "name": "Select",
      "import": "import { Select } from '@uraniumtech/ui'",
      "source": "src/components/Select.tsx",
      "replaces": ["hand-styled <select>", "custom listbox re-implementations"],
      "props": "options {value,label}[]; value; onChange; ...native select props",
      "example": "<Select options={[{value:'u3o8',label:'U3O8'}]} value={m} onChange={setM} aria-label=\"Material\" />"
    },
    {
      "name": "Checkbox",
      "import": "import { Checkbox } from '@uraniumtech/ui'",
      "source": "src/components/Checkbox.tsx",
      "replaces": ["raw <input type=\"checkbox\">"],
      "props": "label; checked; onChange; disabled?",
      "example": "<Checkbox label=\"Delivered\" checked={d} onChange={setD} />"
    },
    {
      "name": "Radio",
      "import": "import { Radio } from '@uraniumtech/ui'",
      "source": "src/components/Checkbox.tsx",
      "replaces": ["raw <input type=\"radio\">"],
      "props": "label; name; value; checked; onChange; disabled?",
      "example": "<Radio label=\"Utility\" name=\"kind\" value=\"utility\" checked={k==='utility'} onChange={setK} />"
    },
    {
      "name": "Switch",
      "import": "import { Switch } from '@uraniumtech/ui'",
      "source": "src/components/Checkbox.tsx",
      "replaces": ["hand-rolled toggle switches"],
      "props": "label; checked; onChange; disabled?",
      "example": "<Switch label=\"Live pricing\" checked={live} onChange={setLive} />"
    },
    {
      "name": "Modal",
      "import": "import { Modal } from '@uraniumtech/ui'",
      "source": "src/components/Modal.tsx",
      "replaces": ["SweetAlert", "hand-rolled modal overlays"],
      "props": "open; onClose; title; children; className?",
      "example": "<Modal open={open} onClose={close} title=\"Edit contract\">…</Modal>"
    },
    {
      "name": "ConfirmDialog",
      "import": "import { ConfirmDialog } from '@uraniumtech/ui'",
      "source": "src/components/Modal.tsx",
      "replaces": ["window.confirm", "SweetAlert confirm dialogs"],
      "props": "open; onClose; onConfirm; title; message; confirmLabel?; cancelLabel?",
      "example": "<ConfirmDialog open={open} onClose={close} onConfirm={remove} title=\"Delete\" message=\"This cannot be undone.\" />"
    },
    {
      "name": "ToastProvider",
      "import": "import { ToastProvider } from '@uraniumtech/ui'",
      "source": "src/components/Toast.tsx",
      "replaces": ["SweetAlert/Notifications-style toasts"],
      "props": "children",
      "example": "<ToastProvider><App /></ToastProvider>"
    },
    {
      "name": "useToast",
      "import": "import { useToast } from '@uraniumtech/ui'",
      "source": "src/components/Toast.tsx",
      "replaces": ["hand-rolled snackbars"],
      "props": "() => { showToast({message, tone?, durationMs?}) }",
      "example": "const { showToast } = useToast(); showToast({ message: 'Saved', tone: 'success' });"
    },
    {
      "name": "Dropdown",
      "import": "import { Dropdown } from '@uraniumtech/ui'",
      "source": "src/components/Dropdown.tsx",
      "replaces": ["hand-rolled popover menus"],
      "props": "trigger (single element); items {label,onSelect,disabled?}[]; align?='start'|'end'",
      "example": "<Dropdown trigger={<Button size=\"sm\">Actions</Button>} items={[{label:'Edit',onSelect:edit}]} />"
    },
    {
      "name": "Tag",
      "import": "import { Tag } from '@uraniumtech/ui'",
      "source": "src/components/Tag.tsx",
      "replaces": ["hand-rolled removable chips"],
      "props": "label; onRemove?; className?",
      "example": "<Tag label=\"Utility\" onRemove={remove} />"
    },
    {
      "name": "TagInput",
      "import": "import { TagInput } from '@uraniumtech/ui'",
      "source": "src/components/Tag.tsx",
      "replaces": ["third-party tag-input libraries"],
      "props": "value: string[]; onChange; ariaLabel?; placeholder?",
      "example": "<TagInput value={materials} onChange={setMaterials} ariaLabel=\"Materials\" />"
    },
    {
      "name": "Slider",
      "import": "import { Slider } from '@uraniumtech/ui'",
      "source": "src/components/Slider.tsx",
      "replaces": ["nouislider", "hand-rolled draggable sliders"],
      "props": "min; max; value; onChange; step?=1; ariaLabel (required); showValue?",
      "example": "<Slider ariaLabel=\"Discount\" min={0} max={10} value={d} onChange={setD} showValue />"
    },
    {
      "name": "Pagination",
      "import": "import { Pagination } from '@uraniumtech/ui'",
      "source": "src/components/Pagination.tsx",
      "replaces": ["hand-rolled page-number button rows"],
      "props": "page; pageCount; onPageChange; className?",
      "example": "<Pagination page={page} pageCount={pageCount} onPageChange={setPage} />"
    }
  ]
}

---
// Gallery of every library component, light + dark. check-manifest.mjs verifies
// each manifest component renders here (names live in Gallery.tsx sections):
// Button, Kicker, Badge, StatusBadge, Card, PageHeader, StatCard,
// SegmentedControl, Tabs, Tooltip, ThemeToggle, DataTable, LineChart, BarChart,
// FormField, Input, Select, Checkbox, Radio, Switch, Modal, ConfirmDialog,
// ToastProvider, useToast, Dropdown, Tag, TagInput, Slider, Pagination.
import "../styles/docs.css";
import { Gallery } from "../Gallery";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>@uraniumtech/ui gallery</title>
  </head>
  <body>
    <div id="light">
      <Gallery client:load />
    </div>
    <div id="dark" data-theme="dark" class="bg-ut-bg">
      <Gallery client:load />
    </div>
  </body>
</html>
